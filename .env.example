# Database Configuration
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=verify-full"
DB_SSL="true"
DB_CONNECT_TIMEOUT_MS="15000"

# Server Configuration
NODE_ENV="development"
PORT="3001"
BACKEND_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# S3/Filebase Configuration
S3_REGION="us-east-1"
S3_ENDPOINT="https://s3.filebase.com"
S3_BUCKET="sfc-rom"
FILEBASE_BUCKET="sfc-rom"
S3_ACCESS_KEY_ID="your_s3_access_key"
S3_SECRET_ACCESS_KEY="your_s3_secret_key"
S3_FORCE_PATH_STYLE="true"
FILEBASE_IPFS_RPC_ENDPOINT="https://rpc.filebase.io"

# Admin Configuration
ADMIN_BOOTSTRAP_USERNAME="admin"
ADMIN_BOOTSTRAP_PASSWORD="Admin1234!"
ADMIN_BOOTSTRAP_EMAIL="admin@local.admin"
ROM_ADMIN_KEY="your_rom_admin_key_here"

# Download Configuration
DOWNLOAD_REQUIRE_LIBRARY="false"

# Session Configuration
SESSION_TTL_MS="604800000"

# Optional: Google Gemini API (for poster enrichment)
GEMINI_API_KEY=""

# CORS Configuration
CORS_ENABLED="true"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
